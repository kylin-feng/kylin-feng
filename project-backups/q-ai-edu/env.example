# QAI智能助手 - 环境变量配置示例
# 复制此文件为 .env.local 并填写实际配置值

# 应用基础配置
APP_NAME=QAI智能助手
APP_VERSION=1.0.0

# API接口配置
API_BASE_URL=https://api.qai-assistant.com
WS_URL=wss://ws.qai-assistant.com
UPLOAD_URL=https://upload.qai-assistant.com

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 支付配置
WECHAT_MERCHANT_ID=your_merchant_id
WECHAT_PAY_KEY=your_pay_key

# AI服务配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_MODEL=gpt-3.5-turbo

# 阿里云配置（用于存储、短信等服务）
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET=your_oss_bucket
ALIYUN_OSS_REGION=your_oss_region

# 数据库配置
DATABASE_URL=your_database_url
REDIS_URL=your_redis_url

# JWT配置
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 功能开关
ENABLE_REGISTRATION=true
ENABLE_GUEST_MODE=false
ENABLE_VOICE_INPUT=true
ENABLE_IMAGE_UPLOAD=true

# 限制配置
MAX_MESSAGE_LENGTH=2000
FREE_TOKENS_PER_DAY=100
MAX_CONVERSATIONS_PER_USER=50
MAX_MESSAGES_PER_CONVERSATION=100

# 第三方服务配置
SENTRY_DSN=your_sentry_dsn
ANALYTICS_KEY=your_analytics_key

# 开发环境特定配置
DEBUG=true
MOCK_API=false
ENABLE_VCONSOLE=true 