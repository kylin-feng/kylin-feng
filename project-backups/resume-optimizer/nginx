server {
    server_name airix.com.cn www.airix.com.cn;

    # 修改为静态网站配置
    root /var/www/airix.com.cn;
    index index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }

    # 完整的安全头部配置
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # 错误页面配置
    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;

    # 日志配置
    access_log /var/log/nginx/airix.com.cn.access.log;
    error_log /var/log/nginx/airix.com.cn.error.log;

    # 禁止访问隐藏文件
    location ~ /\. {
        deny all;
    }

    # 静态文件缓存配置
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|doc|docx)$ {
        expires 1y;
        add_header Cache-Control "public, no-transform";
        add_header Vary "Accept-Encoding";
        access_log off;
    }

    # HTML文件缓存配置
    location ~* \.html$ {
        expires 1h;
        add_header Cache-Control "public, must-revalidate";
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/airix.com.cn/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/airix.com.cn/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}

