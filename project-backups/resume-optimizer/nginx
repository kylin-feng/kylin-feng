        # 设置CORS - 允许多个域名
        set $cors_origin "";
        if ($http_origin ~* "^https?://(aigchacker\.com|aigcbox\.com\.cn|aigcland\.cn|goaigc\.com\.cn|airix\.com\.cn)$") {
